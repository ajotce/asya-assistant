APP_ENV=local
ASYA_HOST=127.0.0.1
ASYA_PORT=8000
LOG_LEVEL=INFO
SERVE_FRONTEND=true
FRONTEND_DIST_PATH=../frontend/dist
AUTH_REGISTRATION_MODE=open
AUTH_COOKIE_NAME=asya_session
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_HOURS=168
AUTH_SESSION_HASH_SECRET=change-me-in-local-env
SIGNUP_TOKEN_TTL_HOURS=48
PUBLIC_BASE_URL=http://localhost:8000
MASTER_ENCRYPTION_KEY=

VSELLM_API_KEY=
VSELLM_BASE_URL=https://api.vsellm.ru/v1
DEFAULT_ASSISTANT_NAME=Asya
DEFAULT_CHAT_MODEL=openai/gpt-5
DEFAULT_SYSTEM_PROMPT=Ты — Asya, персональный ИИ-ассистент пользователя. Общайся на русском языке и работай только в рамках текущей сессии.
DEFAULT_EMBEDDING_MODEL=

SQLITE_PATH=/app/data/asya.sqlite3
ASYA_DB_PATH=/app/data/asya-0.2.sqlite3
TMP_DIR=/app/tmp
MAX_FILES_PER_MESSAGE=10
MAX_FILE_SIZE_MB=256

MEMORY_EXTRACTION_ENABLED=true

# Integrations
LINEAR_OAUTH_CLIENT_ID=your-linear-client-id
LINEAR_OAUTH_CLIENT_SECRET=your-linear-client-secret

GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
TODOIST_OAUTH_CLIENT_ID=your-todoist-client-id
TODOIST_OAUTH_CLIENT_SECRET=your-todoist-client-secret
OAUTH_STATE_TTL_SECONDS=900
LINEAR_OAUTH_REDIRECT_URI=https://asya.example.com/api/integrations/linear/callback
GOOGLE_OAUTH_REDIRECT_URI=https://asya.example.com/api/integrations/google/callback
TODOIST_OAUTH_REDIRECT_URI=https://asya.example.com/api/integrations/todoist/callback

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_LINK_TOKEN_TTL_SECONDS=900
TELEGRAM_LINK_WEBHOOK_SECRET=change-me
TELEGRAM_WEBHOOK_URL=https://asya.example.com/api/integrations/telegram/webhook

# Voice
YANDEX_SPEECHKIT_API_KEY=your-speechkit-key
YANDEX_SPEECHKIT_FOLDER_ID=your-folder-id
GIGACHAT_API_KEY=your-gigachat-key
VOICE_MAX_AUDIO_BYTES=15728640
VOICE_TTS_ENABLED_DEFAULT=false

# Email transport (alpha/beta access links)
EMAIL_TRANSPORT=mock
EMAIL_FROM=noreply@asya.example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=change-me
SMTP_USE_TLS=true

# Reverse proxy / domain
PUBLIC_DOMAIN=asya.example.com
